{
  "name": "@opensocial/protocol-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "pnpm --filter @opensocial/protocol-client build",
    "build": "tsc -p tsconfig.json",
    "pretest": "pnpm --filter @opensocial/protocol-client build",
    "pretypecheck": "pnpm --filter @opensocial/protocol-client build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test": "vitest run"
  },
  "dependencies": {
    "@opensocial/protocol-client": "workspace:*",
    "@opensocial/protocol-types": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
