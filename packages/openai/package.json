{
  "name": "@opensocial/openai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./agents": {
      "types": "./dist/agents.d.ts",
      "import": "./dist/agents.js",
      "default": "./dist/agents.js"
    },
    "./failure-replay": {
      "types": "./dist/failure-replay.d.ts",
      "import": "./dist/failure-replay.js",
      "default": "./dist/failure-replay.js"
    },
    "./golden-intent-dataset": {
      "types": "./dist/golden-intent-dataset.d.ts",
      "import": "./dist/golden-intent-dataset.js",
      "default": "./dist/golden-intent-dataset.js"
    },
    "./prompts": {
      "types": "./dist/prompts.d.ts",
      "import": "./dist/prompts.js",
      "default": "./dist/prompts.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "test": "echo 'no tests yet for openai package'"
  },
  "dependencies": {
    "@opensocial/types": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "openai": "^6.32.0",
    "zod": "^4.3.6"
  }
}
