NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opensocial
REDIS_URL=redis://localhost:6379
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4.1-mini
OPENAI_MODEL_INTENT_PARSING=
OPENAI_MODEL_FOLLOW_UP_QUESTION=
OPENAI_MODEL_SUGGESTION_GENERATION=
OPENAI_MODEL_RANKING_EXPLANATION=
OPENAI_MODEL_NOTIFICATION_COPY=
OPENAI_MODEL_MODERATION_ASSIST=
OPENAI_MODERATION_ENABLED=true
# User Google sign-in (web + mobile). If GOOGLE_CLIENT_ID is unset, GET /api/auth/google returns 503.
GOOGLE_CLIENT_ID=195638449372-o5f6jkmokd0lfh1unl6r885i1n8olcu8.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
JWT_ACCESS_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me
JWT_ACCESS_SECRETS=
JWT_REFRESH_SECRETS=
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=opensocial-media
MEDIA_CDN_BASE_URL=http://localhost:9000/opensocial-media
MEDIA_UPLOAD_SIGNING_SECRET=
S3_PRESIGNED_UPLOADS_ENABLED=false
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=opensocial-api
OTEL_SERVICE_VERSION=0.1.0
REQUEST_SECURITY_ENABLED=true
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_MAX_REQUESTS=300
RATE_LIMIT_WRITE_WINDOW_MS=60000
RATE_LIMIT_WRITE_MAX_REQUESTS=150
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX_REQUESTS=40
ABUSE_THROTTLE_WINDOW_MS=30000
ABUSE_THROTTLE_MAX_SCORE=32
ABUSE_THROTTLE_BLOCK_MS=300000
ADMIN_SECURITY_ENABLED=true
# If set, every /api/admin request must send x-admin-api-key. The admin web app no longer collects this; leave empty for operator Google sign-in only.
ADMIN_API_KEY=
ADMIN_ALLOWED_USER_IDS=
ADMIN_ROLE_BINDINGS=
# Comma-separated full URLs (e.g. https://admin.example.com/auth/callback) allowed as Google OAuth return targets for the admin app. If unset, only http(s)://localhost|127.0.0.1/auth/callback is allowed.
ADMIN_DASHBOARD_REDIRECT_URIS=
# Comma-separated emails allowed to complete admin-app Google sign-in (`adminConsole: true` on token exchange). Defaults to jeffersonlicet@gmail.com when unset.
ADMIN_CONSOLE_ALLOWED_EMAILS=
# Comma-separated full callback URLs for the web app (production). Local dev allows
# http(s)://localhost or 127.0.0.1 with path /auth/callback without this list.
WEB_APP_REDIRECT_URIS=
ENFORCE_HTTPS=false
SECURITY_STRICT_MODE=false
DB_ENCRYPTION_AT_REST=false
OBJECT_STORAGE_ENCRYPTION_AT_REST=false
REDIS_TLS_ENABLED=false
ALERT_QUEUE_BACKLOG_THRESHOLD=250
ALERT_WEBSOCKET_ERROR_THRESHOLD=25
ALERT_WEBSOCKET_ERROR_RATE_THRESHOLD=0.2
ALERT_DB_LATENCY_THRESHOLD_MS=500
ALERT_OPENAI_ERROR_RATE_THRESHOLD=0.25
ALERT_OPENAI_MIN_CALLS_THRESHOLD=20
ALERT_MODERATION_BACKLOG_THRESHOLD=150
VIDEO_TRANSCRIPTS_MAX_BYTES=262144000
TERMS_OF_SERVICE_URL=
PRIVACY_POLICY_URL=
LEGAL_TERMS_VERSION=v1
LEGAL_PRIVACY_VERSION=v1
LEGAL_MINIMUM_AGE=18
LEGAL_REGION_MODE=off
LEGAL_REGION_COUNTRY_CODES=
FEATURE_GLOBAL_KILL_SWITCH=false
FEATURE_INVITE_ONLY_MODE=false
FEATURE_ALPHA_COHORT_USER_IDS=
FEATURE_ENABLE_NEW_INTENTS=true
FEATURE_ENABLE_AGENT_FOLLOWUPS=true
FEATURE_ENABLE_GROUP_FORMATION=true
FEATURE_ENABLE_PUSH_NOTIFICATIONS=true
FEATURE_ENABLE_PERSONALIZATION=true
FEATURE_ENABLE_DISCOVERY=true
FEATURE_ENABLE_MODERATION_STRICTNESS=false
FEATURE_ENABLE_MODERATION_MESSAGES=true
FEATURE_ENABLE_MODERATION_AVATARS=true
FEATURE_ENABLE_AI_PARSING=true
MODERATION_DECISION_RETENTION_DAYS=180
MODERATION_STRIKE_DECAY_WINDOW_DAYS=30
FEATURE_ENABLE_REALTIME_CHAT=true
REALTIME_ALLOW_INSECURE_USER_ID=false
INBOX_EXPIRE_STALE_CRON_KEY=

# --- Web & mobile clients (optional overrides) ---
# Web (`apps/web`): production builds default to https://api.opensocial.so/api when unset.
# Local dev uses http://localhost:3000/api unless you set:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
#
# Mobile (`apps/mobile`): defaults to https://api.opensocial.so/api (prod API) when unset.
# Explicit prod (optional; same as default). Host-only values get https + /api:
# EXPO_PUBLIC_API_BASE_URL=api.opensocial.so
# EXPO_PUBLIC_API_BASE_URL=https://api.opensocial.so/api
# Local API during Expo dev (pick one):
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:3000/api
# EXPO_PUBLIC_USE_LOCAL_API=1
#
# Welcome screen: bundled apps/mobile/assets/video/welcome-bg.mp4 by default.
# Optional: override with your hosted MP4 (see apps/mobile/docs/welcome-backdrop.md).
# EXPO_PUBLIC_WELCOME_VIDEO_URI=https://cdn.example.com/opensocial/welcome-loop.mp4
