{
  "name": "@opensocial/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && pnpm run start",
    "prebuild": "pnpm --filter @opensocial/types build && pnpm --filter @opensocial/openai build",
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "prestart": "pnpm run build",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --max-warnings=0",
    "pretypecheck": "pnpm run prisma:generate && pnpm --filter @opensocial/types build && pnpm --filter @opensocial/openai build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm run prisma:generate && pnpm --filter @opensocial/types build && pnpm --filter @opensocial/openai build",
    "test": "vitest run",
    "prisma:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/opensocial} prisma generate --config ../../prisma.config.ts",
    "prisma:migrate": "pnpm run prisma:migrate:dev",
    "prisma:migrate:dev": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/opensocial} prisma migrate dev --config ../../prisma.config.ts",
    "prisma:migrate:deploy": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/opensocial} prisma migrate deploy --config ../../prisma.config.ts",
    "prisma:migrate:status": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/opensocial} prisma migrate status --config ../../prisma.config.ts",
    "prisma:migrate:drift-check": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/opensocial} prisma validate --config ../../prisma.config.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.3",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.11",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/platform-socket.io": "^11.0.11",
    "@nestjs/websockets": "^11.0.11",
    "@opensocial/openai": "workspace:*",
    "@opensocial/types": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.46.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.10.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.11",
    "@types/express": "^5.0.1",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.1.0",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "vitest": "^4.1.0"
  }
}
