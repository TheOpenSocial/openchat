{
  "expo": {
    "name": "OpenSocial",
    "slug": "opensocial",
    "version": "0.1.0",
    "scheme": "opensocial",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "OpenSocial uses your photo library so you can add a profile picture during onboarding."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "so.opensocial.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "OpenSocial uses the microphone for voice input when composing intents and messages.",
        "NSSpeechRecognitionUsageDescription": "OpenSocial uses speech recognition to turn your voice into text."
      },
      "appleTeamId": "FJ6SU8G5YM"
    },
    "android": {
      "package": "so.opensocial.app",
      "permissions": ["android.permission.RECORD_AUDIO"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    }
  }
}
