{
  "name": "@opensocial/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "predev": "pnpm --filter @opensocial/protocol-types build && pnpm --filter @opensocial/protocol-client build",
    "dev": "expo start",
    "prebuild": "pnpm --filter @opensocial/protocol-types build && pnpm --filter @opensocial/protocol-client build",
    "prebuild:ios": "expo prebuild --platform ios",
    "run:ios": "expo run:ios",
    "run:ios:device": "expo run:ios --device",
    "jarvis:device": "expo run:ios --device \"Jarvis mobile\"",
    "build": "pnpm build:ios && pnpm build:android",
    "build:ios": "expo export --platform ios --output-dir dist-ios",
    "build:android": "expo export --platform android --output-dir dist-android",
    "lint": "eslint App.tsx \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "pretypecheck": "pnpm --filter @opensocial/protocol-types build && pnpm --filter @opensocial/protocol-client build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm --filter @opensocial/protocol-types build && pnpm --filter @opensocial/protocol-client build",
    "test": "vitest run",
    "test:e2e:maestro": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-host.exp.Exponent} MAESTRO_EXPO_URL=${MAESTRO_EXPO_URL:-exp://localhost:8089} maestro test .maestro/mobile-critical-path.yaml",
    "test:e2e:maestro:daily-loop": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-host.exp.Exponent} MAESTRO_EXPO_URL=${MAESTRO_EXPO_URL:-exp://localhost:8089} maestro test .maestro/mobile-daily-loop.yaml",
    "test:e2e:maestro:daily-loop:native": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-so.opensocial.app} maestro test .maestro/mobile-daily-loop-native.yaml",
    "test:e2e:maestro:route-graph": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-host.exp.Exponent} MAESTRO_EXPO_URL=${MAESTRO_EXPO_URL:-exp://localhost:8089} maestro test .maestro/mobile-route-graph.yaml",
    "test:e2e:maestro:surface-smoke": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-so.opensocial.app} MAESTRO_EXPO_URL=${MAESTRO_EXPO_URL:-exp://localhost:8089} maestro test .maestro/mobile-surface-smoke.yaml",
    "test:e2e:maestro:sandbox-surface": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-so.opensocial.app} MAESTRO_EXPO_URL=${MAESTRO_EXPO_URL:-exp://localhost:8089} maestro test .maestro/mobile-sandbox-surface-smoke.yaml",
    "test:e2e:maestro:sandbox-surface:expo-go": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-host.exp.Exponent} MAESTRO_EXPO_URL=${MAESTRO_EXPO_URL:-exp://localhost:8089} maestro test .maestro/mobile-sandbox-surface-smoke-expo-go.yaml",
    "test:e2e:maestro:sandbox-surface:expo-go:attached": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-host.exp.Exponent} maestro test .maestro/mobile-sandbox-surface-smoke-expo-go-attached.yaml",
    "test:e2e:maestro:sandbox-surface:expo-go:current": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-host.exp.Exponent} maestro test .maestro/mobile-sandbox-surface-smoke-expo-go-current.yaml",
    "test:e2e:maestro:sandbox-home-activity:expo-go:attached": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-host.exp.Exponent} maestro test .maestro/mobile-sandbox-home-activity-expo-go-attached.yaml",
    "test:e2e:maestro:sandbox-activity-target:expo-go:attached": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-host.exp.Exponent} maestro test .maestro/mobile-sandbox-activity-target-expo-go-attached.yaml",
    "test:e2e:maestro:sandbox-activity-target:expo-go:current": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-host.exp.Exponent} maestro test .maestro/mobile-sandbox-activity-target-from-current-expo-go-attached.yaml",
    "test:e2e:maestro:profile-persistence": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-host.exp.Exponent} MAESTRO_EXPO_URL=${MAESTRO_EXPO_URL:-exp://localhost:8089} maestro test .maestro/mobile-profile-persistence.yaml",
    "test:e2e:maestro:settings-persistence": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-host.exp.Exponent} MAESTRO_EXPO_URL=${MAESTRO_EXPO_URL:-exp://localhost:8089} maestro test .maestro/mobile-settings-persistence.yaml",
    "test:e2e:maestro:chats-core": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-host.exp.Exponent} MAESTRO_EXPO_URL=${MAESTRO_EXPO_URL:-exp://localhost:8089} maestro test .maestro/mobile-chats-core.yaml",
    "test:e2e:maestro:design": "MAESTRO_APP_ID=${MAESTRO_APP_ID:-host.exp.Exponent} MAESTRO_EXPO_URL=${MAESTRO_EXPO_URL:-exp://localhost:8089} maestro test .maestro/mobile-design-mock.yaml"
  },
  "dependencies": {
    "@expo-google-fonts/google-sans-flex": "^0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@opensocial/protocol-client": "workspace:*",
    "@opensocial/protocol-types": "workspace:*",
    "@opensocial/types": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.5.2",
    "@tanstack/react-query": "^5.99.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "^55.0.8",
    "expo-blur": "~55.0.10",
    "expo-constants": "^55.0.9",
    "expo-device": "^55.0.10",
    "expo-glass-effect": "~55.0.8",
    "expo-haptics": "^55.0.9",
    "expo-image-picker": "~55.0.0",
    "expo-linear-gradient": "^55.0.9",
    "expo-linking": "^55.0.8",
    "expo-notifications": "~55.0.16",
    "expo-speech-recognition": "^3.1.2",
    "expo-splash-screen": "~55.0.0",
    "expo-status-bar": "~55.0.4",
    "expo-video": "^55.0.0",
    "expo-web-browser": "^55.0.10",
    "lottie-react-native": "^7.3.6",
    "nativewind": "5.0.0-preview.3",
    "react": "19.2.3",
    "react-native": "0.83.2",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-toast-message": "^2.3.3",
    "react-native-worklets": "^0.7.2",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.0.11",
    "lightningcss": "1.30.1",
    "postcss": "^8.5.8",
    "vitest": "^4.1.0"
  }
}
