model CommerceOffer {
  id            String             @id @default(uuid()) @db.Uuid
  listingId     String             @map("listing_id") @db.Uuid
  buyerUserId   String             @map("buyer_user_id") @db.Uuid
  sellerUserId  String             @map("seller_user_id") @db.Uuid
  offerPrice    Decimal            @map("offer_price") @db.Decimal(12, 2)
  currency      String
  message       String?
  status        CommerceOfferStatus @default(proposed)
  metadata      Json?
  workflowRunId String             @map("workflow_run_id")
