generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, vector]
}

enum UserStatus {
  active
  suspended
  deleted
}

enum IntentStatus {
  draft
  parsed
  matching
  fanout
  partial
  connected
  expired
  cancelled
}

enum RequestStatus {
  pending
  accepted
  rejected
  expired
  cancelled
}

enum ConnectionType {
  dm
  group
}

enum ChatType {
  dm
  group
}

enum ModerationState {
  clean
  flagged
  blocked
  review
}

enum AvailabilityMode {
  now
  later_today
  flexible
  away
  invisible
}

model User {
  id              String      @id @default(uuid()) @db.Uuid
  email           String?     @unique
  googleSubjectId String?     @unique @map("google_subject_id")
  displayName     String      @map("display_name")
  username        String?     @unique
  locale          String      @default("en")
  timezone        String      @default("UTC")
  status          UserStatus  @default(active)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  profile         UserProfile?
  inferredPreferences InferredPreference[]
  explicitPreferences ExplicitPreference[]
  preferenceFeedbackEvents PreferenceFeedbackEvent[]
  sessions        UserSession[]

  @@map("users")
}

model UserProfile {
  userId            String           @id @db.Uuid @map("user_id")
  bio               String?
  city              String?
  country           String?
  visibility        String           @default("public")
  onboardingState   String           @default("not_started") @map("onboarding_state")
  availabilityMode  AvailabilityMode @default(flexible) @map("availability_mode")
  trustScore        Decimal          @default(0.0) @db.Decimal(5, 2) @map("trust_score")
  moderationState   ModerationState  @default(clean) @map("moderation_state")
  lastActiveAt      DateTime?        @map("last_active_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests         UserInterest[]
  topics            UserTopic[]
  availabilityWindows UserAvailabilityWindow[]

  @@map("user_profiles")
}

model UserSession {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid @map("user_id")
  deviceId         String?  @map("device_id")
  deviceName       String?  @map("device_name")
  userAgent        String?  @map("user_agent")
  ipAddress        String?  @map("ip_address")
  refreshTokenHash String   @map("refresh_token_hash")
  status           String   @default("active")
  expiresAt        DateTime @map("expires_at")
  lastUsedAt       DateTime @default(now()) @map("last_used_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, lastUsedAt])
  @@index([expiresAt, status])
  @@map("user_sessions")
}

model UserProfileImage {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid @map("user_id")
  originalUrl String   @map("original_url")
  thumbUrl    String?  @map("thumb_url")
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_profile_images")
}

model UserInterest {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid @map("user_id")
  kind            String
  label           String
  normalizedLabel String   @map("normalized_label")
  weight          Decimal  @default(1.0) @db.Decimal(4, 2)
  source          String   @default("user")
  createdAt       DateTime @default(now()) @map("created_at")
  userProfile     UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, kind])
  @@map("user_interests")
}

model UserTopic {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid @map("user_id")
  label            String
  normalizedLabel  String   @map("normalized_label")
  weight           Decimal  @default(1.0) @db.Decimal(4, 2)
  source           String   @default("user")
  createdAt        DateTime @default(now()) @map("created_at")
  userProfile      UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, normalizedLabel])
  @@index([userId, normalizedLabel])
  @@map("user_topics")
}

model UserAvailabilityWindow {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid @map("user_id")
  dayOfWeek   Int      @map("day_of_week")
  startMinute Int      @map("start_minute")
  endMinute   Int      @map("end_minute")
  mode        String   @default("available")
  timezone    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  userProfile UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, dayOfWeek])
  @@index([userId, startMinute, endMinute])
  @@map("user_availability_windows")
}

model UserPreference {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  key        String
  value      Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([userId, key])
  @@map("user_preferences")
}

model InferredPreference {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid @map("user_id")
  preferenceKey String   @map("preference_key")
  value         Json
  confidence    Decimal  @db.Decimal(4, 3)
  sourceSignal  String   @map("source_signal")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, preferenceKey])
  @@map("inferred_preferences")
}

model ExplicitPreference {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid @map("user_id")
  scope         String
  preferenceKey String   @map("preference_key")
  value         Json
  source        String   @default("user")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scope, preferenceKey])
  @@map("explicit_preferences")
}

model PreferenceFeedbackEvent {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid @map("user_id")
  preferenceKey String   @map("preference_key")
  feedbackType  String   @map("feedback_type")
  signalStrength Decimal @db.Decimal(4, 3) @map("signal_strength")
  context       Json?
  createdAt     DateTime @default(now()) @map("created_at")
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, preferenceKey, createdAt])
  @@map("preference_feedback_events")
}

model UserRule {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  scope      String
  ruleType   String   @map("rule_type")
  payload    Json
  priority   Int
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, isActive])
  @@map("user_rules")
}

model AgentThread {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  title      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  messages   AgentMessage[]

  @@index([userId, createdAt])
  @@map("agent_threads")
}

model AgentMessage {
  id              String   @id @default(uuid()) @db.Uuid
  threadId        String   @db.Uuid @map("thread_id")
  createdByUserId String?  @db.Uuid @map("created_by_user_id")
  role            String
  content         String
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")
  thread          AgentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("agent_messages")
}

model Intent {
  id           String      @id @default(uuid()) @db.Uuid
  userId       String      @db.Uuid @map("user_id")
  rawText      String      @map("raw_text")
  status       IntentStatus
  parsedIntent Json?       @map("parsed_intent")
  confidence   Decimal?    @db.Decimal(4, 3)
  safetyState  ModerationState @default(clean) @map("safety_state")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([userId, status])
  @@map("intents")
}

model IntentCandidate {
  id               String   @id @default(uuid()) @db.Uuid
  intentId         String   @db.Uuid @map("intent_id")
  candidateUserId  String   @db.Uuid @map("candidate_user_id")
  score            Decimal  @db.Decimal(6, 5)
  rationale        Json?
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([intentId, score])
  @@map("intent_candidates")
}

model IntentRequest {
  id              String       @id @default(uuid()) @db.Uuid
  intentId         String       @db.Uuid @map("intent_id")
  senderUserId     String       @db.Uuid @map("sender_user_id")
  recipientUserId  String       @db.Uuid @map("recipient_user_id")
  status           RequestStatus @default(pending)
  wave             Int          @default(1)
  relevanceFeatures Json?       @map("relevance_features")
  sentAt           DateTime     @default(now()) @map("sent_at")
  respondedAt      DateTime?    @map("responded_at")
  expiresAt        DateTime?    @map("expires_at")

  @@index([recipientUserId, status])
  @@index([intentId, status])
  @@map("intent_requests")
}

model RequestResponse {
  id         String   @id @default(uuid()) @db.Uuid
  requestId  String   @db.Uuid @map("request_id")
  userId     String   @db.Uuid @map("user_id")
  action     String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([requestId])
  @@map("request_responses")
}

model Connection {
  id              String         @id @default(uuid()) @db.Uuid
  type            ConnectionType
  originIntentId  String?        @db.Uuid @map("origin_intent_id")
  createdByUserId String         @db.Uuid @map("created_by_user_id")
  status          String         @default("active")
  createdAt       DateTime       @default(now()) @map("created_at")
  participants    ConnectionParticipant[]
  chats           Chat[]

  @@map("connections")
}

model ConnectionParticipant {
  id            String   @id @default(uuid()) @db.Uuid
  connectionId  String   @db.Uuid @map("connection_id")
  userId        String   @db.Uuid @map("user_id")
  role          String   @default("member")
  joinedAt      DateTime @default(now()) @map("joined_at")
  leftAt        DateTime? @map("left_at")
  connection    Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, userId])
  @@map("connection_participants")
}

model Chat {
  id           String   @id @default(uuid()) @db.Uuid
  connectionId String   @db.Uuid @map("connection_id")
  type         ChatType
  createdAt    DateTime @default(now()) @map("created_at")
  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@index([connectionId])
  @@map("chats")
}

model ChatMembership {
  id         String   @id @default(uuid()) @db.Uuid
  chatId      String  @db.Uuid @map("chat_id")
  userId      String  @db.Uuid @map("user_id")
  joinedAt    DateTime @default(now()) @map("joined_at")

  @@index([chatId, userId])
  @@map("chat_memberships")
}

model ChatMessage {
  id            String   @id @default(uuid()) @db.Uuid
  chatId         String  @db.Uuid @map("chat_id")
  senderUserId   String  @db.Uuid @map("sender_user_id")
  body           String
  moderationState ModerationState @default(clean) @map("moderation_state")
  createdAt      DateTime @default(now()) @map("created_at")
  chat           Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  receipts       MessageReceipt[]

  @@index([chatId, createdAt])
  @@map("chat_messages")
}

model ChatMessageArchive {
  id               String   @id @default(uuid()) @db.Uuid
  sourceMessageId  String   @unique @db.Uuid @map("source_message_id")
  chatId           String   @db.Uuid @map("chat_id")
  senderUserId     String   @db.Uuid @map("sender_user_id")
  body             String
  moderationState  ModerationState @map("moderation_state")
  originalCreatedAt DateTime @map("original_created_at")
  archivedAt       DateTime @default(now()) @map("archived_at")

  @@index([chatId, originalCreatedAt])
  @@index([archivedAt])
  @@map("chat_messages_archive")
}

model MessageReceipt {
  id          String   @id @default(uuid()) @db.Uuid
  messageId   String   @db.Uuid @map("message_id")
  userId      String   @db.Uuid @map("user_id")
  deliveredAt DateTime? @map("delivered_at")
  readAt      DateTime? @map("read_at")
  message     ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, userId])
  @@map("message_receipts")
}

model Notification {
  id              String   @id @default(uuid()) @db.Uuid
  recipientUserId String   @db.Uuid @map("recipient_user_id")
  type            String
  body            String
  channel         String   @default("in_app")
  isRead          Boolean  @default(false) @map("is_read")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([recipientUserId, isRead])
  @@map("notifications")
}

model ModerationFlag {
  id           String   @id @default(uuid()) @db.Uuid
  entityType   String   @map("entity_type")
  entityId     String   @db.Uuid @map("entity_id")
  reason       String
  status       String   @default("open")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([entityType, status])
  @@map("moderation_flags")
}

model UserReport {
  id             String   @id @default(uuid()) @db.Uuid
  reporterUserId String   @db.Uuid @map("reporter_user_id")
  targetUserId   String?  @db.Uuid @map("target_user_id")
  reason         String
  details        String?
  status         String   @default("open")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([reporterUserId, status])
  @@map("user_reports")
}

model Block {
  id            String   @id @default(uuid()) @db.Uuid
  blockerUserId String   @db.Uuid @map("blocker_user_id")
  blockedUserId String   @db.Uuid @map("blocked_user_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([blockerUserId, blockedUserId])
  @@map("blocks")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorUserId String? @db.Uuid @map("actor_user_id")
  actorType  String   @map("actor_type")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @db.Uuid @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, createdAt])
  @@map("audit_logs")
}

model AuditLogArchive {
  id                String   @id @default(uuid()) @db.Uuid
  sourceAuditLogId  String   @unique @db.Uuid @map("source_audit_log_id")
  actorUserId       String?  @db.Uuid @map("actor_user_id")
  actorType         String   @map("actor_type")
  action            String
  entityType        String   @map("entity_type")
  entityId          String?  @db.Uuid @map("entity_id")
  metadata          Json?
  originalCreatedAt DateTime @map("original_created_at")
  archivedAt        DateTime @default(now()) @map("archived_at")

  @@index([entityType, originalCreatedAt])
  @@index([archivedAt])
  @@map("audit_logs_archive")
}

model OutboxEvent {
  id           String   @id @default(uuid()) @db.Uuid
  aggregateType String  @map("aggregate_type")
  aggregateId  String   @db.Uuid @map("aggregate_id")
  eventType    String   @map("event_type")
  payload      Json
  publishedAt  DateTime? @map("published_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([publishedAt])
  @@map("outbox_events")
}

model AdminAction {
  id          String   @id @default(uuid()) @db.Uuid
  adminUserId String   @db.Uuid @map("admin_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @db.Uuid @map("entity_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([adminUserId, createdAt])
  @@map("admin_actions")
}

model LifeGraphNode {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  nodeType   String   @map("node_type")
  label      String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, nodeType])
  @@map("life_graph_nodes")
}

model LifeGraphEdge {
  id           String   @id @default(uuid()) @db.Uuid
  userId        String  @db.Uuid @map("user_id")
  sourceNodeId  String  @db.Uuid @map("source_node_id")
  targetNodeId  String  @db.Uuid @map("target_node_id")
  edgeType      String  @map("edge_type")
  weight        Decimal @db.Decimal(5, 4)
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([userId, edgeType])
  @@map("life_graph_edges")
}

model RetrievalDocument {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  docType    String   @map("doc_type")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, docType])
  @@map("retrieval_documents")
}

model RetrievalChunk {
  id           String   @id @default(uuid()) @db.Uuid
  documentId   String   @db.Uuid @map("document_id")
  chunkIndex   Int      @map("chunk_index")
  content      String
  tokenCount   Int      @map("token_count")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([documentId, chunkIndex])
  @@map("retrieval_chunks")
}

model Embedding {
  id           String   @id @default(uuid()) @db.Uuid
  ownerType    String   @map("owner_type")
  ownerId      String   @db.Uuid @map("owner_id")
  embeddingType String  @map("embedding_type")
  model        String
  vector       Unsupported("vector(1536)")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([ownerType, ownerId])
  @@map("embeddings")
}
