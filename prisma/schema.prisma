generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgcrypto, vector]
}

enum UserStatus {
  active
  suspended
  deleted
}

enum IntentStatus {
  draft
  parsed
  matching
  fanout
  partial
  connected
  expired
  cancelled
}

enum RequestStatus {
  pending
  accepted
  rejected
  expired
  cancelled
}

enum ConnectionType {
  dm
  group
}

enum ChatType {
  dm
  group
}

enum ModerationState {
  clean
  flagged
  blocked
  review
}

enum AvailabilityMode {
  now
  later_today
  flexible
  away
  invisible
}

enum DatingConsentStatus {
  pending
  granted
  revoked
}

enum DatingVerificationStatus {
  unverified
  verified
  rejected
}

enum CommerceListingStatus {
  active
  paused
  removed
  fulfilled
}

enum CommerceOfferStatus {
  proposed
  countered
  accepted
  rejected
  expired
  cancelled
  escrowed
  fulfilled
  disputed
}

enum CommerceEscrowStatus {
  not_started
  pending_funding
  funded
  released
  refunded
  frozen
}

enum CommerceDisputeStatus {
  open
  under_review
  resolved_refund
  resolved_release
  rejected
}

model User {
  id                         String                    @id @default(uuid()) @db.Uuid
  email                      String?                   @unique
  googleSubjectId            String?                   @unique @map("google_subject_id")
  displayName                String                    @map("display_name")
  username                   String?                   @unique
  locale                     String                    @default("en")
  timezone                   String                    @default("UTC")
  status                     UserStatus                @default(active)
  createdAt                  DateTime                  @default(now()) @map("created_at")
  updatedAt                  DateTime                  @updatedAt @map("updated_at")
  profile                    UserProfile?
  inferredPreferences        InferredPreference[]
  explicitPreferences        ExplicitPreference[]
  preferenceFeedbackEvents   PreferenceFeedbackEvent[]
  sessions                   UserSession[]
  scheduledTasks             ScheduledTask[]
  scheduledTaskRuns          ScheduledTaskRun[]
  savedSearches              SavedSearch[]
  ownedRecurringCircles      RecurringCircle[]         @relation("RecurringCircleOwner")
  recurringCircleMemberships RecurringCircleMember[]
  workflowDomainIntents      WorkflowDomainIntent[]
  datingConsentArtifacts     DatingConsentArtifact[]
  commerceListings           CommerceListing[]
  commerceOffersAsBuyer      CommerceOffer[]           @relation("CommerceOfferBuyer")
  commerceOffersAsSeller     CommerceOffer[]           @relation("CommerceOfferSeller")
  commerceDisputesOpened     CommerceDispute[]

  @@map("users")
}

model UserProfile {
  userId              String                   @id @map("user_id") @db.Uuid
  bio                 String?
  city                String?
  country             String?
  visibility          String                   @default("public")
  onboardingState     String                   @default("not_started") @map("onboarding_state")
  availabilityMode    AvailabilityMode         @default(flexible) @map("availability_mode")
  trustScore          Decimal                  @default(0.0) @map("trust_score") @db.Decimal(5, 2)
  moderationState     ModerationState          @default(clean) @map("moderation_state")
  lastActiveAt        DateTime?                @map("last_active_at")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests           UserInterest[]
  topics              UserTopic[]
  availabilityWindows UserAvailabilityWindow[]

  @@map("user_profiles")
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  deviceId         String?   @map("device_id")
  deviceName       String?   @map("device_name")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  refreshTokenHash String    @map("refresh_token_hash")
  status           String    @default("active")
  expiresAt        DateTime  @map("expires_at")
  lastUsedAt       DateTime  @default(now()) @map("last_used_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, lastUsedAt])
  @@index([expiresAt, status])
  @@map("user_sessions")
}

model UserProfileImage {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  originalUrl String   @map("original_url")
  thumbUrl    String?  @map("thumb_url")
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_profile_images")
}

model UserInterest {
  id              String      @id @default(uuid()) @db.Uuid
  userId          String      @map("user_id") @db.Uuid
  kind            String
  label           String
  normalizedLabel String      @map("normalized_label")
  weight          Decimal     @default(1.0) @db.Decimal(4, 2)
  source          String      @default("user")
  createdAt       DateTime    @default(now()) @map("created_at")
  userProfile     UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, kind])
  @@map("user_interests")
}

model UserTopic {
  id              String      @id @default(uuid()) @db.Uuid
  userId          String      @map("user_id") @db.Uuid
  label           String
  normalizedLabel String      @map("normalized_label")
  weight          Decimal     @default(1.0) @db.Decimal(4, 2)
  source          String      @default("user")
  createdAt       DateTime    @default(now()) @map("created_at")
  userProfile     UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, normalizedLabel])
  @@index([userId, normalizedLabel])
  @@map("user_topics")
}

model UserAvailabilityWindow {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  dayOfWeek   Int         @map("day_of_week")
  startMinute Int         @map("start_minute")
  endMinute   Int         @map("end_minute")
  mode        String      @default("available")
  timezone    String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  userProfile UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, dayOfWeek])
  @@index([userId, startMinute, endMinute])
  @@map("user_availability_windows")
}

model UserPreference {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  key       String
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, key])
  @@map("user_preferences")
}

model InferredPreference {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  preferenceKey String   @map("preference_key")
  value         Json
  confidence    Decimal  @db.Decimal(4, 3)
  sourceSignal  String   @map("source_signal")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, preferenceKey])
  @@map("inferred_preferences")
}

model ExplicitPreference {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  scope         String
  preferenceKey String   @map("preference_key")
  value         Json
  source        String   @default("user")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scope, preferenceKey])
  @@map("explicit_preferences")
}

model PreferenceFeedbackEvent {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  preferenceKey  String   @map("preference_key")
  feedbackType   String   @map("feedback_type")
  signalStrength Decimal  @map("signal_strength") @db.Decimal(4, 3)
  context        Json?
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, preferenceKey, createdAt])
  @@map("preference_feedback_events")
}

model UserRule {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  scope     String
  ruleType  String   @map("rule_type")
  payload   Json
  priority  Int
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isActive])
  @@map("user_rules")
}

model AgentThread {
  id              String                @id @default(uuid()) @db.Uuid
  userId          String                @map("user_id") @db.Uuid
  title           String?
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  messages        AgentMessage[]
  planCheckpoints AgentPlanCheckpoint[]

  @@index([userId, createdAt])
  @@map("agent_threads")
}

model AgentMessage {
  id              String      @id @default(uuid()) @db.Uuid
  threadId        String      @map("thread_id") @db.Uuid
  createdByUserId String?     @map("created_by_user_id") @db.Uuid
  role            String
  content         String
  metadata        Json?
  createdAt       DateTime    @default(now()) @map("created_at")
  thread          AgentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("agent_messages")
}

model AgentPlanCheckpoint {
  id               String      @id @default(uuid()) @db.Uuid
  threadId         String      @map("thread_id") @db.Uuid
  userId           String      @map("user_id") @db.Uuid
  traceId          String      @map("trace_id")
  requestedByRole  String      @map("requested_by_role")
  tool             String
  actionType       String      @map("action_type")
  riskLevel        String      @map("risk_level")
  status           String      @default("pending")
  requestMetadata  Json?       @map("request_metadata")
  decisionReason   String?     @map("decision_reason")
  resolvedByUserId String?     @map("resolved_by_user_id") @db.Uuid
  resolvedAt       DateTime?   @map("resolved_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  thread           AgentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, status, createdAt])
  @@index([userId, status, createdAt])
  @@map("agent_plan_checkpoints")
}

model Intent {
  id           String          @id @default(uuid()) @db.Uuid
  userId       String          @map("user_id") @db.Uuid
  rawText      String          @map("raw_text")
  status       IntentStatus
  parsedIntent Json?           @map("parsed_intent")
  confidence   Decimal?        @db.Decimal(4, 3)
  safetyState  ModerationState @default(clean) @map("safety_state")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  @@index([userId, status])
  @@map("intents")
}

model IntentCandidate {
  id              String   @id @default(uuid()) @db.Uuid
  intentId        String   @map("intent_id") @db.Uuid
  candidateUserId String   @map("candidate_user_id") @db.Uuid
  score           Decimal  @db.Decimal(6, 5)
  rationale       Json?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([intentId, score])
  @@map("intent_candidates")
}

model IntentRequest {
  id                String        @id @default(uuid()) @db.Uuid
  intentId          String        @map("intent_id") @db.Uuid
  senderUserId      String        @map("sender_user_id") @db.Uuid
  recipientUserId   String        @map("recipient_user_id") @db.Uuid
  status            RequestStatus @default(pending)
  wave              Int           @default(1)
  relevanceFeatures Json?         @map("relevance_features")
  sentAt            DateTime      @default(now()) @map("sent_at")
  respondedAt       DateTime?     @map("responded_at")
  expiresAt         DateTime?     @map("expires_at")

  @@index([recipientUserId, status])
  @@index([intentId, status])
  @@map("intent_requests")
}

model RequestResponse {
  id        String   @id @default(uuid()) @db.Uuid
  requestId String   @map("request_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([requestId])
  @@map("request_responses")
}

model Connection {
  id              String                  @id @default(uuid()) @db.Uuid
  type            ConnectionType
  originIntentId  String?                 @map("origin_intent_id") @db.Uuid
  createdByUserId String                  @map("created_by_user_id") @db.Uuid
  status          String                  @default("active")
  createdAt       DateTime                @default(now()) @map("created_at")
  participants    ConnectionParticipant[]
  chats           Chat[]

  @@map("connections")
}

model ConnectionParticipant {
  id           String     @id @default(uuid()) @db.Uuid
  connectionId String     @map("connection_id") @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  role         String     @default("member")
  joinedAt     DateTime   @default(now()) @map("joined_at")
  leftAt       DateTime?  @map("left_at")
  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, userId])
  @@map("connection_participants")
}

model Chat {
  id           String        @id @default(uuid()) @db.Uuid
  connectionId String        @map("connection_id") @db.Uuid
  type         ChatType
  createdAt    DateTime      @default(now()) @map("created_at")
  connection   Connection    @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@index([connectionId])
  @@map("chats")
}

model ChatMembership {
  id       String   @id @default(uuid()) @db.Uuid
  chatId   String   @map("chat_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at")

  @@index([chatId, userId])
  @@map("chat_memberships")
}

model ChatMessage {
  id              String           @id @default(uuid()) @db.Uuid
  chatId          String           @map("chat_id") @db.Uuid
  senderUserId    String           @map("sender_user_id") @db.Uuid
  body            String
  moderationState ModerationState  @default(clean) @map("moderation_state")
  replyToMessageId String?          @map("reply_to_message_id") @db.Uuid
  createdAt       DateTime         @default(now()) @map("created_at")
  editedAt        DateTime?        @map("edited_at")
  chat            Chat             @relation(fields: [chatId], references: [id], onDelete: Cascade)
  replyToMessage  ChatMessage?     @relation("ChatMessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies         ChatMessage[]    @relation("ChatMessageReplies")
  receipts        MessageReceipt[]
  reactions       ChatMessageReaction[]

  @@index([chatId, createdAt])
  @@index([replyToMessageId])
  @@map("chat_messages")
}

model ChatMessageReaction {
  id         String      @id @default(uuid()) @db.Uuid
  messageId  String      @map("message_id") @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  emoji      String
  createdAt  DateTime    @default(now()) @map("created_at")
  message    ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId, createdAt])
  @@map("chat_message_reactions")
}

model ChatMessageArchive {
  id                String          @id @default(uuid()) @db.Uuid
  sourceMessageId   String          @unique @map("source_message_id") @db.Uuid
  chatId            String          @map("chat_id") @db.Uuid
  senderUserId      String          @map("sender_user_id") @db.Uuid
  body              String
  moderationState   ModerationState @map("moderation_state")
  originalCreatedAt DateTime        @map("original_created_at")
  archivedAt        DateTime        @default(now()) @map("archived_at")

  @@index([chatId, originalCreatedAt])
  @@index([archivedAt])
  @@map("chat_messages_archive")
}

model MessageReceipt {
  id          String      @id @default(uuid()) @db.Uuid
  messageId   String      @map("message_id") @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  deliveredAt DateTime?   @map("delivered_at")
  readAt      DateTime?   @map("read_at")
  message     ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, userId])
  @@map("message_receipts")
}

model Notification {
  id              String   @id @default(uuid()) @db.Uuid
  recipientUserId String   @map("recipient_user_id") @db.Uuid
  type            String
  body            String
  channel         String   @default("in_app")
  isRead          Boolean  @default(false) @map("is_read")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([recipientUserId, isRead])
  @@map("notifications")
}

model ModerationFlag {
  id                   String    @id @default(uuid()) @db.Uuid
  entityType           String    @map("entity_type")
  entityId             String    @map("entity_id") @db.Uuid
  reason               String
  status               String    @default("open")
  assigneeUserId       String?   @map("assignee_user_id") @db.Uuid
  assignmentNote       String?   @map("assignment_note")
  assignedAt           DateTime? @map("assigned_at")
  lastDecision         String?   @map("last_decision")
  triageNote           String?   @map("triage_note")
  triagedByAdminUserId String?   @map("triaged_by_admin_user_id") @db.Uuid
  triagedAt            DateTime? @map("triaged_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  @@index([entityType, status])
  @@index([assigneeUserId, status])
  @@map("moderation_flags")
}

model UserReport {
  id             String   @id @default(uuid()) @db.Uuid
  reporterUserId String   @map("reporter_user_id") @db.Uuid
  targetUserId   String?  @map("target_user_id") @db.Uuid
  reason         String
  details        String?
  status         String   @default("open")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([reporterUserId, status])
  @@map("user_reports")
}

model Block {
  id            String   @id @default(uuid()) @db.Uuid
  blockerUserId String   @map("blocker_user_id") @db.Uuid
  blockedUserId String   @map("blocked_user_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([blockerUserId, blockedUserId])
  @@map("blocks")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  actorType   String   @map("actor_type")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id") @db.Uuid
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([entityType, createdAt])
  @@map("audit_logs")
}

model AuditLogArchive {
  id                String   @id @default(uuid()) @db.Uuid
  sourceAuditLogId  String   @unique @map("source_audit_log_id") @db.Uuid
  actorUserId       String?  @map("actor_user_id") @db.Uuid
  actorType         String   @map("actor_type")
  action            String
  entityType        String   @map("entity_type")
  entityId          String?  @map("entity_id") @db.Uuid
  metadata          Json?
  originalCreatedAt DateTime @map("original_created_at")
  archivedAt        DateTime @default(now()) @map("archived_at")

  @@index([entityType, originalCreatedAt])
  @@index([archivedAt])
  @@map("audit_logs_archive")
}

model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id") @db.Uuid
  eventType     String    @map("event_type")
  payload       Json
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([publishedAt])
  @@map("outbox_events")
}

model ProtocolApp {
  id                 String   @id @default(uuid()) @db.Uuid
  appId              String   @unique @map("app_id")
  status             String   @default("active")
  registrationJson   Json     @map("registration_json")
  manifestJson       Json     @map("manifest_json")
  issuedScopes       String[] @default([]) @map("issued_scopes")
  issuedCapabilities String[] @default([]) @map("issued_capabilities")
  appTokenHash       String   @map("app_token_hash")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  scopeGrants        ProtocolAppScopeGrant[]

  @@index([status, createdAt])
  @@map("protocol_apps")
}

model ProtocolAppScopeGrant {
  id              String    @id @default(uuid()) @db.Uuid
  appId           String    @map("app_id")
  scope           String
  capabilities    String[]  @default([])
  subjectType     String    @default("app") @map("subject_type")
  subjectId       String?   @map("subject_id")
  status          String    @default("active")
  grantedByUserId String?   @map("granted_by_user_id") @db.Uuid
  grantedAt       DateTime  @default(now()) @map("granted_at")
  revokedAt       DateTime? @map("revoked_at")
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  app             ProtocolApp @relation(fields: [appId], references: [appId], onDelete: Cascade)

  @@unique([appId, scope, subjectType, subjectId])
  @@index([appId, status, createdAt])
  @@map("protocol_app_scope_grants")
}

model ProtocolWebhookSubscription {
  id            String   @id @default(uuid()) @db.Uuid
  subscriptionId String  @unique @map("subscription_id")
  appId         String   @map("app_id")
  status        String   @default("active")
  targetUrl     String   @map("target_url")
  eventNames    String[] @default([]) @map("event_names")
  resourceNames String[] @default([]) @map("resource_names")
  deliveryMode  String   @default("json") @map("delivery_mode")
  retryPolicy   Json     @map("retry_policy")
  secretRef     String?  @map("secret_ref")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([appId, status, createdAt])
  @@map("protocol_webhook_subscriptions")
}

model ProtocolWebhookDelivery {
  id                 String   @id @default(uuid()) @db.Uuid
  deliveryId         String   @unique @map("delivery_id")
  subscriptionId     String   @map("subscription_id")
  appId              String   @map("app_id")
  eventCursor        BigInt?  @map("event_cursor")
  eventName          String   @map("event_name")
  status             String   @default("queued")
  attemptCount       Int      @default(0) @map("attempt_count")
  nextAttemptAt      DateTime? @map("next_attempt_at")
  lastAttemptAt      DateTime? @map("last_attempt_at")
  deliveredAt        DateTime? @map("delivered_at")
  responseStatusCode Int?     @map("response_status_code")
  errorMessage       String?  @map("error_message")
  signature          String?  
  payload            Json
  metadata           Json?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([subscriptionId, status, createdAt])
  @@index([appId, eventName, createdAt])
  @@map("protocol_webhook_deliveries")
}

model ProtocolWebhookDeliveryAttempt {
  id                 String   @id @default(uuid()) @db.Uuid
  deliveryId         String   @map("delivery_id")
  appId              String   @map("app_id")
  subscriptionId     String   @map("subscription_id")
  attemptNumber      Int      @map("attempt_number")
  outcome            String
  attemptedAt        DateTime @default(now()) @map("attempted_at")
  responseStatusCode Int?     @map("response_status_code")
  errorCode          String?  @map("error_code")
  errorMessage       String?  @map("error_message")
  durationMs         Int?     @map("duration_ms")
  metadata           Json?
