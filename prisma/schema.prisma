model RecurringCircle {
  id                String                   @id @default(uuid()) @db.Uuid
  ownerUserId       String                   @map("owner_user_id") @db.Uuid
  title             String
  description       String?
  status            String                   @default("active")
  visibility        String                   @default("invite_only")
  topicTags         Json?                    @map("topic_tags")
  targetSize        Int?                     @map("target_size")
  cadenceType       String                   @map("cadence_type")
  cadenceConfig     Json                     @map("cadence_config")
  kickoffPrompt     String?                  @map("kickoff_prompt")
