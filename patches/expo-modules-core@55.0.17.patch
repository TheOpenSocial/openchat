diff --git a/ios/EXDefines.h b/ios/EXDefines.h
index 7412ee777be8744d5429ecfb0f8511cb95e3522f..143afa2a4b0ca826a206eeb3942d5442391c8f59 100644
--- a/ios/EXDefines.h
+++ b/ios/EXDefines.h
@@ -93,3 +93,34 @@ typedef struct EXModuleInfo {
 typedef void (^EXDirectEventBlock)(NSDictionary *body);
 typedef void (NS_SWIFT_SENDABLE ^EXPromiseResolveBlock)(id result);
 typedef void (NS_SWIFT_SENDABLE ^EXPromiseRejectBlock)(NSString *code, NSString *message, NSError *error);
+
+// Legacy unimodules type aliases (e.g. expo-av)
+typedef EXPromiseResolveBlock UMPromiseResolveBlock;
+typedef EXPromiseRejectBlock UMPromiseRejectBlock;
+
+NS_ASSUME_NONNULL_BEGIN
+
+NS_INLINE NSError *EXErrorWithMessage(NSString *message)
+{
+  return [NSError errorWithDomain:@"expo.modules.legacy"
+                             code:1
+                         userInfo:@{NSLocalizedDescriptionKey: message ?: @""}];
+}
+
+NS_INLINE void EXFatal(NSError *error)
+{
+  NSString *reason = error.localizedDescription ?: @"fatal error";
+  @throw [NSException exceptionWithName:@"EXFatal" reason:reason userInfo:@{NSUnderlyingErrorKey: error}];
+}
+
+NS_ASSUME_NONNULL_END
+
+#ifndef EXLogWarn
+#define EXLogWarn(...) NSLog(__VA_ARGS__)
