diff --git a/ios/Legacy/Services/EXLegacyEventEmitterService.mm b/ios/Legacy/Services/EXLegacyEventEmitterService.mm
new file mode 100644
index 0000000000000000000000000000000000000000..fcd8a4004ff364cb294ea0c27207de590b126194
--- /dev/null
+++ b/ios/Legacy/Services/EXLegacyEventEmitterService.mm
@@ -0,0 +1,46 @@
+// Bridges legacy EXEventEmitterService to RCTDeviceEventEmitter (SDK 55+).
+#import <React/RCTBridge.h>
+#import <React/RCTBridgeModule.h>
+
+#import <ExpoModulesCore/EXDefines.h>
+#import <ExpoModulesCore/EXEventEmitterService.h>
+#import <ExpoModulesCore/EXInternalModule.h>
+
+@interface EXLegacyEventEmitterService : NSObject <EXInternalModule, RCTBridgeModule, EXEventEmitterService>
+@end
+
+@implementation EXLegacyEventEmitterService
+
+EX_REGISTER_MODULE();
+
+@synthesize bridge = _bridge;
+
++ (NSString *)moduleName
+{
+  return @"EXLegacyEventEmitterService";
+}
+
++ (BOOL)requiresMainQueueSetup
+{
+  return NO;
+}
+
++ (const NSArray<Protocol *> *)exportedInterfaces
+{
+  return @[@protocol(EXEventEmitterService)];
+}
+
+- (void)sendEventWithName:(NSString *)eventName body:(id)body
+{
+  RCTBridge *bridge = self.bridge;
+  if (!bridge) {
+    return;
+  }
+  NSArray *args = body != nil ? @[ eventName, body ] : @[ eventName ];
+  [bridge enqueueJSCall:@"RCTDeviceEventEmitter"
+                 method:@"emit"
+                   args:args
+             completion:NULL];
+}
+
+@end
