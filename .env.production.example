NODE_ENV=production
PORT=3000

# Public API base URL used by admin and web frontend containers.
NEXT_PUBLIC_API_BASE_URL=https://api.opensocial.so/api
CADDY_EMAIL=you@example.com

# Core services
DATABASE_URL=postgresql://<db_user>:<db_password>@<rds_endpoint>:5432/<db_name>?sslmode=require
REDIS_URL=redis://valkey:6379
REDIS_HOST=valkey
REDIS_PORT=6379

# App secrets
JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_long_random_secret
ADMIN_API_KEY=replace_with_long_random_secret
ADMIN_ALLOWED_USER_IDS=
ADMIN_ROLE_BINDINGS=

# Google OAuth
GOOGLE_CLIENT_ID=195638449372-o5f6jkmokd0lfh1unl6r885i1n8olcu8.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://api.openchat.example.com/api/auth/google/callback
ADMIN_DASHBOARD_REDIRECT_URIS=http://admin.openchat.example.com/auth/callback
WEB_APP_REDIRECT_URIS=https://app.openchat.example.com/auth/callback

# OpenAI
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4.1-mini
OPENAI_MODERATION_ENABLED=true
ONBOARDING_LLM_MODEL=
ONBOARDING_LLM_FAST_MODEL=
ONBOARDING_LLM_RICH_MODEL=
ONBOARDING_LLM_TIMEOUT_MS=4000
ONBOARDING_LLM_RICH_TIMEOUT_MS=15000
# Agents runtime is the default. Only set for temporary debugging/fallback.
# OPENAI_AGENTS_FORCE_LEGACY=false

# Object storage (S3 bucket recommended in AWS)
AWS_REGION=us-east-1
S3_ENDPOINT=https://s3.<region>.amazonaws.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=opensocial-media
MEDIA_CDN_BASE_URL=https://<cdn_or_bucket_public_base_url>
MEDIA_UPLOAD_SIGNING_SECRET=replace_with_long_random_secret
S3_PRESIGNED_UPLOADS_ENABLED=true

# Security posture flags
ENFORCE_HTTPS=false
REQUEST_SECURITY_ENABLED=true
ADMIN_SECURITY_ENABLED=true

# Launch controls defaults
FEATURE_ENABLE_MODERATION_STRICTNESS=true
FEATURE_ENABLE_MODERATION_MESSAGES=true
FEATURE_ENABLE_MODERATION_AVATARS=true
MODERATION_DECISION_RETENTION_DAYS=180
MODERATION_STRIKE_DECAY_WINDOW_DAYS=30
