import { BlurView } from "expo-blur";
import { LinearGradient } from "expo-linear-gradient";
import { createRef, memo, useEffect, useMemo } from "react";
import { Modal, StyleSheet, View } from "react-native";
import Animated, {
  Easing,
  interpolate,
  useAnimatedStyle,
  useSharedValue,
  withRepeat,
  withTiming,
  type SharedValue,
} from "react-native-reanimated";

import {
  SystemBlobAnimation,
  type SystemBlobAnimationHandle,
} from "./SystemBlobAnimation";
import { TypingText } from "./TypingText";

type LoadingModalProps = {
  visible: boolean;
  message: string;
};

const ORBITAL_DURATION_MS = 4600;
const ORBITAL_RADIUS_X = 72;
const ORBITAL_RADIUS_Y = 24;
const FULL_ROTATION_DEG = 360;
const ORBITAL_EASING = Easing.bezier(0.22, 0.82, 0.42, 0.98);

const OrbitingBlob = memo(function OrbitingBlob({
  phaseOffsetDeg,
  rotationDeg,
  startFrame,
  progress,
  lottieRef,
}: {
  phaseOffsetDeg: number;
  rotationDeg: number;
  startFrame: number;
  progress: SharedValue<number>;
  lottieRef?: { current: SystemBlobAnimationHandle | null };
}) {
  const animatedStyle = useAnimatedStyle(() => {
    const angleDeg = progress.value + phaseOffsetDeg;
    const angleRad = (angleDeg * Math.PI) / 180;
    const depth = Math.cos(angleRad);
    const translateX = Math.sin(angleRad) * ORBITAL_RADIUS_X;
    const translateY = depth * ORBITAL_RADIUS_Y;

    return {
      opacity: interpolate(depth, [-1, 1], [0.5, 1]),
      transform: [
        { translateX },
        { translateY },
        { scale: interpolate(depth, [-1, 1], [0.82, 1.1]) },
      ],
    };
  });

  return (
    <Animated.View className="absolute" style={animatedStyle}>
      <SystemBlobAnimation
        initialFrame={startFrame}
        lottieRef={lottieRef}
        rotationDeg={rotationDeg}
        size={148}
        staticFrame
      />
    </Animated.View>
  );
});

export function LoadingModal({ visible, message }: LoadingModalProps) {
  const orbitProgress = useSharedValue(0);
  const blobConfigs = useMemo(
    () =>
      Array.from({ length: 3 }, (_, index) => ({
        id: index,
        phaseOffsetDeg:
          index * (FULL_ROTATION_DEG / 3) + (Math.random() * 20 - 10),
        rotationDeg: Math.round(Math.random() * 360),
        startFrame: Math.floor(Math.random() * 600),
      })),
    [],
  );
  const lottieRefs = useMemo(
    () => [
      createRef<SystemBlobAnimationHandle>(),
      createRef<SystemBlobAnimationHandle>(),
      createRef<SystemBlobAnimationHandle>(),
    ],
    [],
  );

  useEffect(() => {
    orbitProgress.value = 0;
    orbitProgress.value = visible
      ? withRepeat(
          withTiming(FULL_ROTATION_DEG, {
            duration: ORBITAL_DURATION_MS,
            easing: ORBITAL_EASING,
          }),
          -1,
          false,
        )
      : withTiming(0, { duration: 220, easing: Easing.out(Easing.cubic) });
  }, [orbitProgress, visible]);

  return (
    <Modal
      animationType="fade"
      onRequestClose={() => {}}
      statusBarTranslucent
      transparent
      visible={visible}
    >
      <View className="flex-1 bg-black">
        <LinearGradient
          colors={["#000000", "#020202", "#000000"]}
          end={{ x: 0.5, y: 1 }}
          start={{ x: 0.5, y: 0 }}
          style={StyleSheet.absoluteFillObject}
        />
        <BlurView intensity={8} style={StyleSheet.absoluteFillObject} tint="dark" />

        <View className="flex-1 items-center justify-center px-6">
          <View className="h-[220px] w-[280px] items-center justify-center">
            {blobConfigs.map((config, index) => (
              <OrbitingBlob
                key={config.id}
                lottieRef={lottieRefs[index]}
                phaseOffsetDeg={config.phaseOffsetDeg}
                progress={orbitProgress}
                rotationDeg={config.rotationDeg}
                startFrame={config.startFrame}
              />
            ))}
          </View>
        </View>

        <View className="absolute inset-x-0 bottom-16 items-center px-8">
          <TypingText
            className="max-w-[320px] text-center text-[15px] leading-[21px] text-white/82"
            cursor
            text={message}
          />
        </View>
      </View>
    </Modal>
  );
}
